<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/abc_ic_ab_back_material"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btn_back"
        android:layout_marginTop="10dp"
        android:text="Contrôle Éclairage"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/title"
        android:layout_marginTop="30dp"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_led_cuisine"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="15dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:focusable="true">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="15dp">
                <ImageView android:id="@+id/img_cuisine" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_bulb" app:tint="#88FFFFFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/img_cuisine" android:layout_marginStart="20dp" android:text="Cuisine" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:id="@+id/status_cuisine" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="OFF" android:textColor="#88FFFFFF"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_led_salon"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="15dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:focusable="true">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="15dp">
                <ImageView android:id="@+id/img_salon" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_bulb" app:tint="#88FFFFFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/img_salon" android:layout_marginStart="20dp" android:text="Salon" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:id="@+id/status_salon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="OFF" android:textColor="#88FFFFFF"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_led_chambre"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:focusable="true">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="15dp">
                <ImageView android:id="@+id/img_chambre" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_bulb" app:tint="#88FFFFFF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/img_chambre" android:layout_marginStart="20dp" android:text="Chambre" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:id="@+id/status_chambre" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="OFF" android:textColor="#88FFFFFF"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</RelativeLayout>